# Local PostgreSQL (Docker)
POSTGRES_CONTAINER_NAME=pillar3-postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=marketing_ai_dev
POSTGRES_USER=marketing_user
POSTGRES_PASSWORD=marketing_pwd_local

# SQLAlchemy-style URL for backend apps
DATABASE_URL=postgresql+psycopg://marketing_user:marketing_pwd_local@localhost:55432/marketing_ai_dev

# Phase 1 default seeded workspace
DEFAULT_WORKSPACE_ID=11111111-1111-1111-1111-111111111111

# Free-first LLM routing
LLM_PRIMARY_PROVIDER=local
LLM_FALLBACK_PROVIDER=groq
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.2
LLM_TOP_P=1.0
LLM_MAX_OUTPUT_TOKENS=1024

# Optional provider models
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-flash

# Optional free-tier API keys (not required in local free mode)
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional n8n webhook integration
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=
N8N_SIGNAL_WEBHOOK_URL=
N8N_CAMPAIGN_OPS_WEBHOOK_URL=
N8N_CREATIVE_MEDIA_WEBHOOK_URL=
N8N_LEARNING_WEBHOOK_URL=
N8N_PUBLISH_WEBHOOK_URL=
N8N_REQUEST_TIMEOUT_SECONDS=3.5
